# Copie para .env e preencha os valores.
# Variáveis VITE_* sobrescrevem public/config.json no build/execução.
# Prioridade ao carregar: config.json → .env → alterações salvas na tela Configuração (navegador)

VITE_SPREADSHEET_ID=
VITE_SHEET_NAME=Escala
VITE_TITULO=Demonstrativo · Escala MESC
VITE_SUBTITULO=Ministério de Escalas · Comunidade
VITE_PERIODO=
VITE_COORDENACAO=

# Chave secreta para liberar Demonstrativo, Planilha e Configuração.
# Não commite o .env. Em produção, defina na hora do build/deploy.
# Acesso: https://seu-site/?admin=SUA_CHAVE (salva neste navegador)
VITE_ADMIN_KEY=

# Mês máximo visível para usuários (AAAA-MM). Também editável em Configuração → escalaLiberadaAte.
VITE_ESCALA_LIBERADA_ATE=
