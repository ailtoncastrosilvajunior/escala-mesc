# Copie para .env e preencha os valores.
#
# Configuração pública (planilha, abas, textos, publicação): public/config.json
# Este arquivo: segredos e overrides locais opcionais.
# Prioridade: config.json → .env → Configuração salva no navegador

# Obrigatório para modo admin (não commite o .env preenchido)
VITE_ADMIN_KEY=

# Overrides opcionais — só descomente se precisar sobrescrever o config.json localmente
# VITE_SPREADSHEET_ID=
# VITE_PADRAO_SHEET_NAME=Escala
# VITE_EXTRA_SHEET_NAME=Escala Extra
# VITE_EXTRA_SERVICOS_SHEET_NAME=Serviços Extra
# VITE_ESCALA_LIBERADA_ATE=2026-07
